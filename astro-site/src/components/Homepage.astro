</div>

<style>
  /* ===== Base / Reset ===== */
  .homepage {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem 3rem;
    font-family: var(--sl-font, system-ui, sans-serif);
  }

  /* ===== Hero Section ===== */
  .hero-section {
    text-align: center;
    padding: 3rem 1rem 2rem;
    margin: -1rem -1.5rem 0;
    background: linear-gradient(135deg, #0f1729 0%, #0a0f1a 100%);
    border-radius: 0 0 16px 16px;
  }

  .hero-title {
    font-size: 2.75rem;
    font-weight: 800;
    margin: 0 0 0.75rem;
    color: #ffffff;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.7);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ===== Tip Banner ===== */
  .tip-banner {
    margin: 1.5rem 0;
  }

  .tip-inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    background: rgba(234, 179, 8, 0.1);
    border: 1px solid rgba(234, 179, 8, 0.3);
    border-radius: 8px;
    color: #eab308;
    font-size: 0.9rem;
  }

  .tip-icon {
    flex-shrink: 0;
  }

  .tip-inner kbd {
    display: inline-block;
    padding: 0.1em 0.45em;
    font-size: 0.85em;
    font-family: var(--sl-font-mono, monospace);
    background: rgba(234, 179, 8, 0.15);
    border: 1px solid rgba(234, 179, 8, 0.4);
    border-radius: 4px;
    line-height: 1;
  }


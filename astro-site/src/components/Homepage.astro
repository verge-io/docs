---
// Homepage.astro - Custom homepage component for VergeOS Docs Starlight site
---

<div class="homepage">
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-content">
      <h1 class="hero-title">VergeOS Docs</h1>
      <p class="hero-subtitle">
        Learn how to get up and running with VergeOS through tutorials, APIs and other resources.
      </p>
    </div>
  </section>

  <!-- Tip Banner -->
  <section class="tip-banner">
    <div class="tip-inner">
      <svg class="tip-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 18h6"></path>
        <path d="M10 22h4"></path>
        <path d="M12 2a7 7 0 0 0-4 12.7V17h8v-2.3A7 7 0 0 0 12 2z"></path>
      </svg>
      <span>Search the docs by pressing <kbd>Ctrl</kbd>+<kbd>K</kbd> (or <kbd>&#8984;</kbd>+<kbd>K</kbd> on Mac)</span>
    </div>
  </section>

  <!-- Main Cards -->
  <section class="main-cards">
    <a href="/product-guide/intro/what-is-vergeos/" class="card main-card">
      <div class="card-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 280 160" class="card-svg">
          <!-- Convergence diagram -->
          <defs>
            <linearGradient id="grad-converge" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" style="stop-color:#D9693B;stop-opacity:0.8" />
              <stop offset="100%" style="stop-color:#D9693B;stop-opacity:0.4" />
            </linearGradient>
          </defs>
          <!-- Source boxes -->
          <rect x="10" y="10" width="70" height="28" rx="4" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.7"/>
          <text x="45" y="28" text-anchor="middle" fill="currentColor" font-size="10" opacity="0.8">Compute</text>
          <rect x="10" y="45" width="70" height="28" rx="4" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.7"/>
          <text x="45" y="63" text-anchor="middle" fill="currentColor" font-size="10" opacity="0.8">Storage</text>
          <rect x="10" y="80" width="70" height="28" rx="4" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.7"/>
          <text x="45" y="98" text-anchor="middle" fill="currentColor" font-size="10" opacity="0.8">Network</text>
          <rect x="10" y="115" width="70" height="28" rx="4" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.7"/>
          <text x="45" y="133" text-anchor="middle" fill="currentColor" font-size="10" opacity="0.8">GPU</text>
          <!-- Arrows -->
          <line x1="85" y1="24" x2="150" y2="75" stroke="currentColor" stroke-width="1" opacity="0.4"/>
          <line x1="85" y1="59" x2="150" y2="75" stroke="currentColor" stroke-width="1" opacity="0.4"/>
          <line x1="85" y1="94" x2="150" y2="85" stroke="currentColor" stroke-width="1" opacity="0.4"/>
          <line x1="85" y1="129" x2="150" y2="90" stroke="currentColor" stroke-width="1" opacity="0.4"/>
          <!-- VergeOS box -->
          <rect x="150" y="50" width="120" height="60" rx="8" fill="url(#grad-converge)" opacity="0.9"/>
          <text x="210" y="78" text-anchor="middle" fill="white" font-size="13" font-weight="600">VergeOS</text>
          <text x="210" y="96" text-anchor="middle" fill="white" font-size="9" opacity="0.8">Unified Platform</text>
        </svg>
      </div>
      <h3 class="card-title">Platform Overview</h3>
      <p class="card-desc">Unified infrastructure converging compute, storage, networking, GPU, and DR into a single operating system</p>
    </a>

    <a href="/product-guide/tools-integrations/nvidia-gpu-virtualization/" class="card main-card">
      <div class="card-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 280 160" class="card-svg">
          <!-- GPU chip diagram -->
          <defs>
            <linearGradient id="grad-gpu" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" style="stop-color:#76b900;stop-opacity:0.8" />
              <stop offset="100%" style="stop-color:#76b900;stop-opacity:0.4" />
            </linearGradient>
          </defs>
          <!-- GPU chip outline -->
          <rect x="70" y="20" width="140" height="120" rx="6" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.5"/>
          <!-- GPU label -->
          <text x="140" y="42" text-anchor="middle" fill="currentColor" font-size="11" font-weight="600" opacity="0.8">NVIDIA GPU</text>
          <!-- MIG partitions -->
          <rect x="82" y="50" width="56" height="36" rx="3" fill="url(#grad-gpu)" opacity="0.7"/>
          <text x="110" y="72" text-anchor="middle" fill="white" font-size="9">MIG 1</text>
          <rect x="142" y="50" width="56" height="36" rx="3" fill="url(#grad-gpu)" opacity="0.7"/>
          <text x="170" y="72" text-anchor="middle" fill="white" font-size="9">MIG 2</text>
          <rect x="82" y="92" width="56" height="36" rx="3" fill="url(#grad-gpu)" opacity="0.7"/>
          <text x="110" y="114" text-anchor="middle" fill="white" font-size="9">MIG 3</text>
          <rect x="142" y="92" width="56" height="36" rx="3" fill="url(#grad-gpu)" opacity="0.7"/>
          <text x="170" y="114" text-anchor="middle" fill="white" font-size="9">vGPU</text>
          <!-- Pins -->
          <line x1="90" y1="140" x2="90" y2="155" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
          <line x1="110" y1="140" x2="110" y2="155" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
          <line x1="130" y1="140" x2="130" y2="155" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
          <line x1="150" y1="140" x2="150" y2="155" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
          <line x1="170" y1="140" x2="170" y2="155" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
          <line x1="190" y1="140" x2="190" y2="155" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
        </svg>
      </div>
      <h3 class="card-title">NVIDIA GPU Virtualization</h3>
      <p class="card-desc">NVIDIA RTX Blackwell 6000 support with vGPU and MIG technologies for GPU-accelerated virtual machines</p>
    </a>

    <a href="/implementation-guide/intro/" class="card main-card">
      <div class="card-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 280 160" class="card-svg">
          <!-- Journey path -->
          <defs>
            <linearGradient id="grad-path" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" style="stop-color:#D9693B;stop-opacity:0.6" />
              <stop offset="100%" style="stop-color:#D9693B;stop-opacity:0.9" />
            </linearGradient>
          </defs>
          <!-- Path line -->
          <path d="M 40 80 Q 100 40 140 80 Q 180 120 240 80" fill="none" stroke="url(#grad-path)" stroke-width="2.5" stroke-dasharray="6 3"/>
          <!-- Step circles -->
          <circle cx="40" cy="80" r="22" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.6"/>
          <text x="40" y="76" text-anchor="middle" fill="currentColor" font-size="16" opacity="0.7">1</text>
          <text x="40" y="90" text-anchor="middle" fill="currentColor" font-size="8" opacity="0.6">Plan</text>
          <circle cx="140" cy="80" r="22" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.6"/>
          <text x="140" y="76" text-anchor="middle" fill="currentColor" font-size="16" opacity="0.7">2</text>
          <text x="140" y="90" text-anchor="middle" fill="currentColor" font-size="8" opacity="0.6">Deploy</text>
          <circle cx="240" cy="80" r="22" fill="none" stroke="#D9693B" stroke-width="2" opacity="0.8"/>
          <text x="240" y="76" text-anchor="middle" fill="#D9693B" font-size="16" font-weight="600">3</text>
          <text x="240" y="90" text-anchor="middle" fill="#D9693B" font-size="8" font-weight="500">Optimize</text>
          <!-- Arrow tip -->
          <polygon points="258,80 252,74 252,86" fill="#D9693B" opacity="0.8"/>
        </svg>
      </div>
      <h3 class="card-title">Get Started</h3>
      <p class="card-desc">Implementation guides, migration paths, and tutorials for deploying VergeOS</p>
    </a>
  </section>

  <!-- Product Guides Section -->
  <section class="section">
    <h2 class="section-title">Product Guides</h2>
    <div class="guide-grid two-col">
      <a href="/product-guide/virtual-machines/overview" class="card guide-card">
        <svg class="guide-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
          <line x1="8" y1="21" x2="16" y2="21"></line>
          <line x1="12" y1="17" x2="12" y2="21"></line>
        </svg>
        <span>Virtualization</span>
      </a>
      <a href="/product-guide/storage/overview" class="card guide-card">
        <svg class="guide-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
          <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path>
          <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path>
        </svg>
        <span>Storage</span>
      </a>
      <a href="/product-guide/networks/network-overview" class="card guide-card">
        <svg class="guide-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="1" y="1" width="6" height="6" rx="1"></rect>
          <rect x="17" y="1" width="6" height="6" rx="1"></rect>
          <rect x="9" y="17" width="6" height="6" rx="1"></rect>
          <path d="M4 7v3a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V7"></path>
          <line x1="12" y1="13" x2="12" y2="17"></line>
        </svg>
        <span>Networking</span>
      </a>
      <a href="/product-guide/backup-dr/overview" class="card guide-card">
        <svg class="guide-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21.5 2v6h-6"></path>
          <path d="M2.5 22v-6h6"></path>
          <path d="M2.5 16A10 10 0 0 1 5.64 5.64"></path>
          <path d="M21.5 8a10 10 0 0 1-3.14 10.36"></path>
        </svg>
        <span>Disaster Recovery</span>
      </a>
      <a href="/product-guide/tools-integrations/nvidia-gpu-virtualization/" class="card guide-card">
        <svg class="guide-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="4" y="4" width="16" height="16" rx="2"></rect>
          <rect x="9" y="9" width="6" height="6"></rect>
          <path d="M15 2v2"></path>
          <path d="M15 20v2"></path>
          <path d="M2 15h2"></path>
          <path d="M2 9h2"></path>
          <path d="M20 15h2"></path>
          <path d="M20 9h2"></path>
          <path d="M9 2v2"></path>
          <path d="M9 20v2"></path>
        </svg>
        <span>NVIDIA vGPU</span>
      </a>
      <a href="/knowledge-base/" class="card guide-card">
        <svg class="guide-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
        </svg>
        <span>Knowledge Base</span>
      </a>
    </div>
  </section>

  <!-- Get Started Section -->
  <section class="section">
    <h2 class="section-title">Get Started</h2>
    <div class="guide-grid three-col">
      <a href="/product-guide/intro/what-is-vergeos/" class="card start-card">
        <svg class="start-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="16" x2="12" y2="12"></line>
          <line x1="12" y1="8" x2="12.01" y2="8"></line>
        </svg>
        <span>Platform Introduction</span>
      </a>
      <a href="/product-guide/ui-overview/" class="card start-card">
        <svg class="start-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
